import java.util.Scanner;

public class Test {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
Scanner scanner = new Scanner(System.in);

		double weight;
		double newweight;
		int choice;
		
		System.out.println("Welcome to weight conversion");
		
		
		System.out.println("1. Convert pounds to kgs");
		System.out.println("2.Convert kgs to pounds");
		
		System.out.print("Your choice ="  );
		choice = scanner.nextInt();
		
		if(choice == 1) {
			System.out.println("your weight in pound is:");
			weight= scanner.nextDouble();
			newweight= weight * 0.453;
			System.out.println("your new weight in kgs  is: " +newweight);
		}else if(choice==2) {
			System.out.println("your weight in kgs is:");
			weight= scanner.nextDouble();
			newweight= weight * 2.204;
			System.out.println("your new weight in pounds is: " +newweight);
		}else {
			System.out.println("INVALID CHOICE !!");
		}
		scanner.close();
	}

}
